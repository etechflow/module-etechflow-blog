<?xml version="1.0"?>
<!--
/**
 * Admin permission resources. Lets store owners grant per-area access
 * (e.g. an editor role that can manage Posts but not Configuration).
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Etechflow_Blog::blog" title="Etechflow Blog" sortOrder="51">
                    <resource id="Etechflow_Blog::post" title="Posts" sortOrder="10"/>
                    <resource id="Etechflow_Blog::category" title="Categories" sortOrder="20"/>
                    <resource id="Etechflow_Blog::tag" title="Tags" sortOrder="30"/>
                    <resource id="Etechflow_Blog::author" title="Authors" sortOrder="40"/>
                    <resource id="Etechflow_Blog::comment" title="Comments" sortOrder="50"/>
                    <resource id="Etechflow_Blog::config" title="Configuration" sortOrder="100"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>

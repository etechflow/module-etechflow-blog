<?xml version="1.0"?>
<!--
/**
 * Content-Security-Policy allowances for common blog content: Cloudinary images
 * and YouTube/Vimeo embeds inside post bodies. Share buttons are plain links so
 * need no CSP entries.
 */
-->
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="img-src">
            <values>
                <value id="cloudinary" type="host">res.cloudinary.com</value>
                <value id="ytimg" type="host">i.ytimg.com</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="youtube" type="host">https://www.youtube.com</value>
                <value id="youtube-nocookie" type="host">https://www.youtube-nocookie.com</value>
                <value id="vimeo" type="host">https://player.vimeo.com</value>
            </values>
        </policy>
        <policy id="media-src">
            <values>
                <value id="cloudinary-media" type="host">res.cloudinary.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>

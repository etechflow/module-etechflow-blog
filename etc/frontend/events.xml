<?xml version="1.0"?>
<!-- Adds the blog link to the storefront top menu when enabled in config. -->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="page_block_html_topmenu_gethtml_before">
        <observer name="etechflow_blog_add_to_top_menu" instance="Etechflow\Blog\Observer\AddBlogToTopMenu"/>
    </event>
    <!-- License gate for the whole blog storefront route (home + every controller). -->
    <event name="controller_action_predispatch_blog">
        <observer name="etechflow_blog_frontend_gate" instance="Etechflow\Blog\Observer\FrontendGate"/>
    </event>
</config>

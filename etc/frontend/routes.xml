<?xml version="1.0"?>
<!--
/**
 * Storefront route. Default blog base path is /blog (configurable via
 * etechflow_blog/general/route — the Router resolves clean permalinks).
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="blog" frontName="blog">
            <module name="Etechflow_Blog"/>
        </route>
    </router>
</config>

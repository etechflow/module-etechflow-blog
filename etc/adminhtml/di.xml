<?xml version="1.0"?>
<!--
/**
 * Intentionally empty. Admin grid data sources (virtualTypes +
 * CollectionFactory "collections") were moved to the global etc/di.xml.
 *
 * Registering grid "collections" in area scope (adminhtml/di.xml) REPLACES the
 * merged global registry instead of extending it, which silently breaks every
 * other module's admin grid with "Not registered handle ...". Keep grid data
 * sources in global etc/di.xml so all modules' entries merge additively.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
</config>

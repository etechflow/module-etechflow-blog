<?xml version="1.0"?>
<!-- Author form. Every field has a how-to hint. -->
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_blog_author_form.etechflow_blog_author_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Author Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="Etechflow\Blog\Block\Adminhtml\Button\BackButton"/>
            <button name="delete" class="Etechflow\Blog\Block\Adminhtml\Button\DeleteButton"/>
            <button name="save" class="Etechflow\Blog\Block\Adminhtml\Button\SaveButton"/>
            <button name="save_and_continue" class="Etechflow\Blog\Block\Adminhtml\Button\SaveAndContinueButton"/>
        </buttons>
        <namespace>etechflow_blog_author_form</namespace>
        <dataScope>data</dataScope>
        <deps><dep>etechflow_blog_author_form.etechflow_blog_author_form_data_source</dep></deps>
    </settings>
    <dataSource name="etechflow_blog_author_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array"><item name="component" xsi:type="string">Magento_Ui/js/form/provider</item></item>
        </argument>
        <settings><submitUrl path="etechflow_blog/author/save"/></settings>
        <dataProvider class="Etechflow\Blog\Model\Author\DataProvider" name="etechflow_blog_author_form_data_source">
            <settings><requestFieldName>author_id</requestFieldName><primaryFieldName>author_id</primaryFieldName></settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general" sortOrder="10">
        <settings><label translate="true">Profile</label></settings>
        <field name="is_active" formElement="checkbox" sortOrder="10">
            <settings>
                <dataType>boolean</dataType><label translate="true">Enabled</label>
                <notice translate="true">Turn off to hide this author's page and byline.</notice>
            </settings>
            <formElements><checkbox><settings><valueMap><map name="false" xsi:type="number">0</map><map name="true" xsi:type="number">1</map></valueMap><prefer>toggle</prefer></settings></checkbox></formElements>
        </field>
        <field name="title" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType><label translate="true">Display Name</label>
                <validation><rule name="required-entry" xsi:type="boolean">true</rule></validation>
                <notice translate="true">The name shown as the byline, e.g. "Jane Smith" or "Editorial Team".</notice>
            </settings>
        </field>
        <field name="identifier" formElement="input" sortOrder="30">
            <settings>
                <dataType>text</dataType><label translate="true">URL Key</label>
                <notice translate="true">Slug for /blog/author/{key}. Leave blank to auto-generate from the name.</notice>
            </settings>
        </field>
        <field name="email" formElement="input" sortOrder="40">
            <settings>
                <dataType>text</dataType><label translate="true">Email</label>
                <notice translate="true">Optional contact email (not shown publicly unless you choose to).</notice>
            </settings>
        </field>
        <field name="image" formElement="input" sortOrder="50">
            <settings>
                <dataType>text</dataType><label translate="true">Avatar Image</label>
                <notice translate="true">Path under pub/media to the author photo shown in the author box.</notice>
            </settings>
        </field>
        <field name="content" formElement="textarea" sortOrder="60">
            <settings>
                <dataType>text</dataType><label translate="true">Bio</label>
                <notice translate="true">Short biography shown in the author box under each post and on the author page.</notice>
            </settings>
        </field>
    </fieldset>

    <fieldset name="social" sortOrder="20">
        <settings><label translate="true">Social Links</label><collapsible>true</collapsible><opened>false</opened></settings>
        <field name="website" formElement="input" sortOrder="10"><settings><dataType>text</dataType><label translate="true">Website</label><notice translate="true">Full URL incl. https://</notice></settings></field>
        <field name="facebook" formElement="input" sortOrder="20"><settings><dataType>text</dataType><label translate="true">Facebook</label><notice translate="true">Full profile URL.</notice></settings></field>
        <field name="twitter" formElement="input" sortOrder="30"><settings><dataType>text</dataType><label translate="true">X / Twitter</label><notice translate="true">Full profile URL.</notice></settings></field>
        <field name="linkedin" formElement="input" sortOrder="40"><settings><dataType>text</dataType><label translate="true">LinkedIn</label><notice translate="true">Full profile URL.</notice></settings></field>
        <field name="instagram" formElement="input" sortOrder="50"><settings><dataType>text</dataType><label translate="true">Instagram</label><notice translate="true">Full profile URL.</notice></settings></field>
    </fieldset>

    <fieldset name="seo" sortOrder="30">
        <settings><label translate="true">SEO</label><collapsible>true</collapsible><opened>false</opened></settings>
        <field name="meta_title" formElement="input" sortOrder="10"><settings><dataType>text</dataType><label translate="true">Meta Title</label><notice translate="true">Defaults to the author name.</notice></settings></field>
        <field name="meta_description" formElement="textarea" sortOrder="20"><settings><dataType>text</dataType><label translate="true">Meta Description</label><notice translate="true">Search snippet for the author page.</notice></settings></field>
    </fieldset>

    <fieldset name="stores" sortOrder="40">
        <settings><label translate="true">Store Views</label><collapsible>true</collapsible><opened>false</opened></settings>
        <field name="store_id" formElement="multiselect" sortOrder="10">
            <settings>
                <dataType>text</dataType><label translate="true">Store Views</label>
                <notice translate="true">Where this author is visible. Pick "All Store Views" for everywhere.</notice>
            </settings>
            <formElements><multiselect><settings><options class="Magento\Cms\Ui\Component\Listing\Column\Cms\Options"/></settings></multiselect></formElements>
        </field>
    </fieldset>
</form>

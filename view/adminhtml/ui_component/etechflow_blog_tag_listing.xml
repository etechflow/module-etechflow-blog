<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_blog_tag_listing.etechflow_blog_tag_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>etechflow_blog_tag_columns</spinner>
        <deps><dep>etechflow_blog_tag_listing.etechflow_blog_tag_listing_data_source</dep></deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/><class>primary</class><label translate="true">Add New Tag</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="etechflow_blog_tag_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig><param name="indexField" xsi:type="string">tag_id</param></storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Etechflow_Blog::tag</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="etechflow_blog_tag_listing_data_source">
            <settings><requestFieldName>tag_id</requestFieldName><primaryFieldName>tag_id</primaryFieldName></settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm><message translate="true">Delete the selected tags?</message><title translate="true">Delete tags</title></confirm>
                    <url path="etechflow_blog/tag/massDelete"/><type>delete</type><label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="etechflow_blog_tag_columns">
        <selectionsColumn name="ids"><settings><indexField>tag_id</indexField></settings></selectionsColumn>
        <column name="tag_id"><settings><filter>textRange</filter><label translate="true">ID</label><sorting>asc</sorting></settings></column>
        <column name="title"><settings><filter>text</filter><label translate="true">Title</label></settings></column>
        <column name="identifier"><settings><filter>text</filter><label translate="true">URL Key</label></settings></column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings><options class="Etechflow\Blog\Model\Source\Status"/><filter>select</filter><dataType>select</dataType><label translate="true">Status</label></settings>
        </column>
        <actionsColumn name="actions" class="Etechflow\Blog\Ui\Component\Listing\Column\Actions">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="indexField" xsi:type="string">tag_id</item>
                    <item name="editUrlPath" xsi:type="string">etechflow_blog/tag/edit</item>
                    <item name="deleteUrlPath" xsi:type="string">etechflow_blog/tag/delete</item>
                </item>
            </argument>
            <settings><indexField>tag_id</indexField></settings>
        </actionsColumn>
    </columns>
</listing>

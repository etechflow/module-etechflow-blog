<?xml version="1.0"?>
<!-- Comment moderation form. Every field has a how-to hint. -->
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_blog_comment_form.etechflow_blog_comment_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Comment</item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="Etechflow\Blog\Block\Adminhtml\Button\BackButton"/>
            <button name="delete" class="Etechflow\Blog\Block\Adminhtml\Button\DeleteButton"/>
            <button name="save" class="Etechflow\Blog\Block\Adminhtml\Button\SaveButton"/>
        </buttons>
        <namespace>etechflow_blog_comment_form</namespace>
        <dataScope>data</dataScope>
        <deps><dep>etechflow_blog_comment_form.etechflow_blog_comment_form_data_source</dep></deps>
    </settings>
    <dataSource name="etechflow_blog_comment_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array"><item name="component" xsi:type="string">Magento_Ui/js/form/provider</item></item>
        </argument>
        <settings><submitUrl path="etechflow_blog/comment/save"/></settings>
        <dataProvider class="Etechflow\Blog\Model\Comment\DataProvider" name="etechflow_blog_comment_form_data_source">
            <settings><requestFieldName>comment_id</requestFieldName><primaryFieldName>comment_id</primaryFieldName></settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general" sortOrder="10">
        <settings><label translate="true">Comment</label></settings>
        <field name="status" formElement="select" sortOrder="10">
            <settings>
                <dataType>text</dataType><label translate="true">Status</label>
                <notice translate="true">Approved comments appear publicly; Pending/Not Approved stay hidden.</notice>
            </settings>
            <formElements><select><settings><options class="Etechflow\Blog\Model\Source\CommentStatus"/></settings></select></formElements>
        </field>
        <field name="author_nickname" formElement="input" sortOrder="20">
            <settings><dataType>text</dataType><label translate="true">Author</label><notice translate="true">Display name of the commenter (read-only context).</notice></settings>
        </field>
        <field name="author_email" formElement="input" sortOrder="30">
            <settings><dataType>text</dataType><label translate="true">Email</label><notice translate="true">Commenter's email (never shown publicly).</notice></settings>
        </field>
        <field name="text" formElement="textarea" sortOrder="40">
            <settings>
                <dataType>text</dataType><label translate="true">Comment Text</label>
                <notice translate="true">You can lightly edit the comment (e.g. remove spam links) before approving.</notice>
            </settings>
        </field>
        <field name="admin_reply" formElement="textarea" sortOrder="50">
            <settings>
                <dataType>text</dataType><label translate="true">Admin Reply</label>
                <notice translate="true">Optional staff reply shown beneath the comment.</notice>
            </settings>
        </field>
    </fieldset>
</form>

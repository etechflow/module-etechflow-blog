<?xml version="1.0"?>
<!-- Category form. Every field has a how-to hint. -->
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_blog_category_form.etechflow_blog_category_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Category Information</item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="Etechflow\Blog\Block\Adminhtml\Button\BackButton"/>
            <button name="delete" class="Etechflow\Blog\Block\Adminhtml\Button\DeleteButton"/>
            <button name="save" class="Etechflow\Blog\Block\Adminhtml\Button\SaveButton"/>
            <button name="save_and_continue" class="Etechflow\Blog\Block\Adminhtml\Button\SaveAndContinueButton"/>
        </buttons>
        <namespace>etechflow_blog_category_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>etechflow_blog_category_form.etechflow_blog_category_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="etechflow_blog_category_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="etechflow_blog/category/save"/>
        </settings>
        <dataProvider class="Etechflow\Blog\Model\Category\DataProvider" name="etechflow_blog_category_form_data_source">
            <settings>
                <requestFieldName>category_id</requestFieldName>
                <primaryFieldName>category_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general" sortOrder="10">
        <settings><label translate="true">General</label></settings>
        <field name="is_active" formElement="checkbox" sortOrder="10">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Enabled</label>
                <notice translate="true">Turn off to hide this category and its page from the storefront.</notice>
            </settings>
            <formElements><checkbox><settings><valueMap><map name="false" xsi:type="number">0</map><map name="true" xsi:type="number">1</map></valueMap><prefer>toggle</prefer></settings></checkbox></formElements>
        </field>
        <field name="title" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType><label translate="true">Title</label>
                <validation><rule name="required-entry" xsi:type="boolean">true</rule></validation>
                <notice translate="true">Category name shown on the page and in the sidebar list.</notice>
            </settings>
        </field>
        <field name="identifier" formElement="input" sortOrder="30">
            <settings>
                <dataType>text</dataType><label translate="true">URL Key</label>
                <notice translate="true">Slug for /blog/category/{key}. Leave blank to auto-generate from the title.</notice>
            </settings>
        </field>
        <field name="parent_id" formElement="select" sortOrder="40">
            <settings>
                <dataType>text</dataType><label translate="true">Parent Category</label>
                <notice translate="true">Optional. Nest this category under another to build a hierarchy.</notice>
            </settings>
            <formElements><select><settings><options class="Etechflow\Blog\Model\Source\Category"/><caption translate="true">-- None (top level) --</caption></settings></select></formElements>
        </field>
        <field name="include_in_menu" formElement="checkbox" sortOrder="50">
            <settings>
                <dataType>boolean</dataType><label translate="true">Show In Blog Menu</label>
                <notice translate="true">Include this category in the blog's navigation menu.</notice>
            </settings>
            <formElements><checkbox><settings><valueMap><map name="false" xsi:type="number">0</map><map name="true" xsi:type="number">1</map></valueMap><prefer>toggle</prefer></settings></checkbox></formElements>
        </field>
        <field name="content" sortOrder="60">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">string</item>
                    <item name="wysiwyg" xsi:type="boolean">true</item>
                    <item name="label" xsi:type="string" translate="true">Description</item>
                    <item name="formElement" xsi:type="string">wysiwyg</item>
                    <item name="source" xsi:type="string">category</item>
                    <item name="notice" xsi:type="string" translate="true">Optional intro text shown at the top of the category page.</item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="seo" sortOrder="20">
        <settings><label translate="true">SEO</label><collapsible>true</collapsible><opened>false</opened></settings>
        <field name="meta_title" formElement="input" sortOrder="10">
            <settings><dataType>text</dataType><label translate="true">Meta Title</label><notice translate="true">Browser/Google title. Defaults to the category title.</notice></settings>
        </field>
        <field name="meta_description" formElement="textarea" sortOrder="20">
            <settings><dataType>text</dataType><label translate="true">Meta Description</label><notice translate="true">Search snippet, ~150–160 characters.</notice></settings>
        </field>
        <field name="meta_keywords" formElement="textarea" sortOrder="30">
            <settings><dataType>text</dataType><label translate="true">Meta Keywords</label><notice translate="true">Comma-separated keywords (optional).</notice></settings>
        </field>
    </fieldset>

    <fieldset name="stores" sortOrder="30">
        <settings><label translate="true">Store Views</label><collapsible>true</collapsible><opened>false</opened></settings>
        <field name="store_id" formElement="multiselect" sortOrder="10">
            <settings>
                <dataType>text</dataType><label translate="true">Store Views</label>
                <notice translate="true">Where this category is visible. Pick "All Store Views" for everywhere.</notice>
            </settings>
            <formElements><multiselect><settings><options class="Magento\Cms\Ui\Component\Listing\Column\Cms\Options"/></settings></multiselect></formElements>
        </field>
    </fieldset>
</form>
